@{
    ViewData["Title"] = $"Detalle {ViewBag.MesLabel}";
    Layout = "_Layout";
    var mes = ViewBag.Mes as string ?? "";
    var mesLabel = ViewBag.MesLabel as string ?? mes;
    var usuario = ViewBag.Usuario as string ?? "";
}

<!-- Breadcrumb -->
<nav class="breadcrumb-punteo" aria-label="breadcrumb">
    <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
    <span> › </span>
    <span>@mesLabel</span>
</nav>

<!-- Nivel 1: Días del mes -->
<section class="section-card" id="seccionDias">
    <div class="section-header">
        <h2 class="section-title">📅 Días — @mesLabel</h2>
    </div>
    <div id="diasLoading" class="skeleton-rows">
        <div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div>
    </div>
    <div id="diasTabla" class="d-none">
        <div class="punteo-table-wrap">
        <table class="punteo-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th class="text-end">Total Registros</th>
                    <th class="text-end">Planillas</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="diasTbody"></tbody>
        </table>
        </div>
        <div id="pagDias" class="tabla-footer d-none"></div>
    </div>
    <div id="diasVacio" class="empty-state d-none">
        <span>📭</span><p>No hay registros para @mesLabel.</p>
    </div>
</section>

<!-- Nivel 2: Panel de registros del día (se inyecta aquí) -->
<div id="panelDia" class="d-none mt-4">
    <section class="section-card">
        <div class="section-header">
            <h2 class="section-title" id="panelDiaTitulo">📋 Registros del día</h2>
            <button class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-2 px-3 rounded-pill fw-medium" onclick="cerrarPanel()" title="Cerrar panel (cancela la descarga activa si hay una)">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/>
                </svg>
                Cerrar
            </button>
        </div>

        <!-- Barra de progreso batch -->
        <div id="panelProgreso" class="progreso-container mb-3 d-none">
            <div class="d-flex justify-content-between mb-1 small text-muted">
                <span>Verificando soportes...</span>
                <span id="panelProgContador">0 / 0</span>
            </div>
            <div class="progress-batch">
                <div id="panelProgFill" class="progress-batch__fill" style="width:0%"></div>
            </div>
        </div>

        <!-- KPI: visible después de verificar soportes -->
        <div id="panelKpi" class="kpi-strip mb-3 d-none">
            <div class="kpi-card">
                <span class="kpi-value" id="kpiTotal">0</span>
                <span class="kpi-label">Total archivos</span>
            </div>
            <div class="kpi-card kpi-card--green">
                <span class="kpi-value" id="kpiEncontrados">0</span>
                <span class="kpi-label">Encontrados</span>
                <button id="btnDescargarTodos" class="btn btn-sm btn-success kpi-btn mt-2"
                        onclick="descargarTodos()" disabled>
                    ⬇ Descargar todos
                </button>
                <div class="kpi-prefix-group mt-2">
                    <label class="small text-muted d-block mb-1">Descargar por prefijo</label>
                    <div class="input-group input-group-sm">
                        <input type="text" id="inputPrefijo" class="form-control"
                               placeholder="Ej: KI" maxlength="20" autocomplete="off" />
                        <button id="btnDescargarPrefijo" class="btn btn-sm btn-outline-success"
                                onclick="descargarPorPrefijo()" disabled>
                            ⬇ Prefijo
                        </button>
                    </div>
                </div>
            </div>
            <div class="kpi-card kpi-card--red">
                <span class="kpi-value" id="kpiFaltantes">0</span>
                <span class="kpi-label">Faltantes</span>
                <div class="kpi-btn-group mt-2">
                    <button id="btnVerFaltantes" class="btn btn-sm btn-outline-danger kpi-btn"
                            onclick="verFaltantes()" disabled>
                        🔍 Ver
                    </button>
                    <button id="btnDescargarLista" class="btn btn-sm btn-danger kpi-btn"
                            onclick="descargarListaFaltantes()" disabled>
                        📊 Descargar lista
                    </button>
                </div>
            </div>
        </div>

        <!-- Barra de progreso descarga ZIP -->
        <div id="zipProgreso" class="progreso-container mb-3 d-none">
            <div class="d-flex justify-content-between mb-1 small text-muted">
                <span id="zipProgresoLabel">Preparando ZIP...</span>
                <span id="zipProgresoPct"></span>
            </div>
            <div class="progress-batch">
                <div id="zipProgresoFill" class="progress-batch__fill" style="width:0%"></div>
            </div>
        </div>

        <div id="panelLoading" class="skeleton-rows d-none">
            <div class="skeleton"></div><div class="skeleton"></div>
        </div>

        <div id="panelTabla" class="d-none">
            <div class="punteo-table-wrap">
            <table class="punteo-table">
                <thead>
                    <tr>
                        <th>Nrodcto</th>
                        <th>Destino</th>
                        <th class="text-end">Cuota Mod</th>
                        <th>Nro. Planilla</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody id="panelTbody"></tbody>
            </table>
            </div>
            <div id="pagPanel" class="tabla-footer d-none"></div>
        </div>
    </section>
</div>

@section Scripts {
<script>
    const MES_ACTUAL = '@mes';
</script>
<script src="~/js/detalle.js" asp-append-version="true"></script>
}
